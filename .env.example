# github-usage-dashboard — environment reference.
# Copy to `.env` and fill in for live mode:  cp .env.example .env
# With nothing set, the app runs in DEMO mode (bundled sample CSVs, no secrets).

# ── Mode ────────────────────────────────────────────────────────────────────
# demo | live. Leave unset to auto-detect (live when a target + auth are set).
APP_MODE=

# ── Datastore ───────────────────────────────────────────────────────────────
# Postgres is first-class (recommended). Point at any reachable Postgres:
DATABASE_URL=postgresql://gud:gud@db:5432/gud
# Leave DATABASE_URL empty to fall back to file-backed SQLite at DB_PATH below.

# ── GitHub billing scope (set org, enterprise, or both) ─────────────────────
GITHUB_ORG=
GITHUB_ENTERPRISE=
# For GitHub Enterprise Server, point at its API (e.g. https://ghe.example.com/api/v3)
GITHUB_API_BASE=https://api.github.com

# ── Auth: GitHub App (default) ──────────────────────────────────────────────
# Create a GitHub App with read access to "Administration"/"Plan" (org billing),
# install it on the org, and note the App ID + Installation ID.
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
# The App private key PEM. Inline (literal \n allowed) …
GITHUB_APP_PRIVATE_KEY=
# … or mount the .pem and point at it instead:
# GITHUB_APP_PRIVATE_KEY_PATH=/etc/github-usage/app-private-key.pem

# ── Auth: PAT override (takes precedence when set) ──────────────────────────
# Recommended for ENTERPRISE billing (GitHub Apps can't always install on an
# enterprise). Needs read-only "Enterprise/Org billing" scope.
GITHUB_TOKEN=

# ── Notifications (each channel enabled only when its config is present) ─────
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=true
REPORT_EMAIL_FROM=
# Comma/semicolon/newline separated list of recipients.
REPORT_EMAIL_TO=

# ── Scheduled delivery (5-field cron; empty = disabled) ─────────────────────
# Examples: daily 08:00 → "0 8 * * *";  Mondays 09:00 → "0 9 * * 1";
#           1st of month 07:00 → "0 7 1 * *".
SCHEDULE_DAILY_CRON=
SCHEDULE_WEEKLY_CRON=
SCHEDULE_MONTHLY_CRON=
SCHEDULE_TIMEZONE=UTC

# ── Misc ────────────────────────────────────────────────────────────────────
# Display currency (ISO 4217) for monetary amounts, e.g. USD, EUR, GBP. GitHub's
# billing API returns bare amounts with no currency, so this is display-only —
# no FX conversion is done. Defaults to USD.
REPORT_CURRENCY=USD
# Public URL shown as the "Open dashboard" link in reports.
PUBLIC_URL=http://localhost:8000
# Seconds a fetched report set is cached before a fresh GitHub pull.
CACHE_TTL_SECONDS=3600
LOG_LEVEL=INFO
